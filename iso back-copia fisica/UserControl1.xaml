<UserControl x:Class="DiskBackupControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="780" MinWidth="980"
             Background="#0E1421">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgA" Color="#0E1421"/>
        <SolidColorBrush x:Key="BgB" Color="#151E30"/>
        <SolidColorBrush x:Key="Panel" Color="#1D2940"/>
        <SolidColorBrush x:Key="AccentA" Color="#FFB703"/>
        <SolidColorBrush x:Key="AccentB" Color="#8ECAE6"/>
        <SolidColorBrush x:Key="Txt" Color="#F1FAFF"/>
        <SolidColorBrush x:Key="SubTxt" Color="#BCD0E5"/>

        <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#223450" Offset="0"/>
            <GradientStop Color="#152038" Offset="0.5"/>
            <GradientStop Color="#0F1727" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource SubTxt}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,6,0,4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F1727"/>
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="BorderBrush" Value="#365276"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0F1727"/>
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="BorderBrush" Value="#365276"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="Margin" Value="0,4,12,8"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#0E1421"/>
            <Setter Property="Background" Value="{StaticResource AccentA}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentB}"/>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource Txt}"/>
            <Setter Property="Background" Value="#304A6D"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeroGradient}" CornerRadius="14" Padding="18" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ISO Back-Copia Fisica Console" Foreground="{StaticResource Txt}" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="UI unificata: backup fisico, workflow EWF completo e fallback RawCopyXsector C++." Foreground="{StaticResource SubTxt}" FontSize="14" Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Label Content="Base URL API"/>
                    <TextBox x:Name="TextBoxApiBase" Text="http://127.0.0.1:9901"/>
                    <WrapPanel>
                        <Button x:Name="ButtonHealth" Content="Health" Width="84"/>
                        <Button x:Name="ButtonMenu" Content="Menu API" Width="96" Style="{StaticResource SecondaryButton}"/>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="{StaticResource BgB}" BorderBrush="#2F4464">
            <TabItem Header="Backup Fisico ISO">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Disco sorgente" Grid.ColumnSpan="2"/>
                        <ComboBox x:Name="ComboBox1" Grid.Column="0" Height="34"/>
                        <Button x:Name="Button2" Grid.Column="1" Content="Aggiorna dischi" Height="34" Style="{StaticResource DarkButton}"/>

                        <Label Content="Percorso file output .img" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,16,0,4"/>
                        <TextBox x:Name="TextBoxFilePath" Grid.Row="3" Grid.Column="0" Height="34"/>
                        <Button x:Name="Button3" Grid.Row="3" Grid.Column="1" Content="Sfoglia" Height="34" Style="{StaticResource DarkButton}"/>

                        <WrapPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,8,0,8">
                            <Button x:Name="Button1" Content="Avvia backup principale" Width="230" Height="38"/>
                            <Button x:Name="ButtonRawApi" Content="Fallback RawCopyXsector API" Width="240" Height="38" Style="{StaticResource SecondaryButton}"/>
                            <Button x:Name="ButtonRawCpp" Content="Fallback RawCopyXsector C++" Width="240" Height="38" Style="{StaticResource DarkButton}"/>
                        </WrapPanel>

                        <ProgressBar x:Name="ProgressBar1" Grid.Row="5" Grid.ColumnSpan="2" Height="24" Margin="0,0,0,8"/>

                        <Border Grid.Row="6" Grid.ColumnSpan="2" Background="{StaticResource Panel}" CornerRadius="10" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Opzioni fallback RawCopyXsector" Foreground="{StaticResource Txt}" FontWeight="Bold"/>
                                <UniformGrid Columns="4" Margin="0,8,0,0">
                                    <StackPanel>
                                        <Label Content="Bytes/sector"/>
                                        <TextBox x:Name="TextBoxRawBytesPerSector" Text="512"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <Label Content="Start sector"/>
                                        <TextBox x:Name="TextBoxRawStartSector" Text="0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <Label Content="Sector count (vuoto = EOF)"/>
                                        <TextBox x:Name="TextBoxRawSectorCount" Text=""/>
                                    </StackPanel>
                                    <StackPanel>
                                        <Label Content="Buffer sectors"/>
                                        <TextBox x:Name="TextBoxRawBufferSectors" Text="2048"/>
                                    </StackPanel>
                                </UniformGrid>
                                <WrapPanel>
                                    <CheckBox x:Name="CheckBoxRawForce" Content="Sovrascrivi output (force)" IsChecked="True"/>
                                    <CheckBox x:Name="CheckBoxRawVerbose" Content="Verbose"/>
                                </WrapPanel>

                                <TextBlock Text="RawCopyXsector C++ DLL" Foreground="{StaticResource Txt}" FontWeight="Bold" Margin="0,6,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TextBoxRawCppDllPath" Grid.Column="0" Margin="0,0,8,8"/>
                                    <Button x:Name="ButtonRawCppBrowseDll" Grid.Column="1" Content="Browse DLL" Style="{StaticResource DarkButton}" Width="108" Height="32"/>
                                    <Button x:Name="ButtonRawCppAutoDetectDll" Grid.Column="2" Content="Auto DLL" Style="{StaticResource SecondaryButton}" Width="96" Height="32"/>
                                </Grid>

                                <TextBlock Text="Fallback automatico su errore backup principale" Foreground="{StaticResource Txt}" FontWeight="Bold" Margin="0,6,0,2"/>
                                <WrapPanel>
                                    <CheckBox x:Name="CheckBoxAutoFallback" Content="Attiva fallback automatico" IsChecked="True"/>
                                    <Label Content="Strategia" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="ComboBoxAutoFallbackMode" Width="240" Height="32">
                                        <ComboBoxItem Content="API poi C++" IsSelected="True"/>
                                        <ComboBoxItem Content="C++ poi API"/>
                                        <ComboBoxItem Content="Solo API"/>
                                        <ComboBoxItem Content="Solo C++"/>
                                    </ComboBox>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="EWF Orchestrator">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource Panel}" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Menu Professionale EWF" Foreground="{StaticResource Txt}" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="Tutte le funzioni del progetto EWF e Read sono eseguibili da qui scegliendo endpoint e payload JSON." Foreground="{StaticResource SubTxt}" Margin="0,4,0,6"/>
                            <TextBlock Text="Preset EWF dedicati (uno per endpoint):" Foreground="{StaticResource SubTxt}" Margin="0,0,0,6"/>
                            <WrapPanel>
                                <Button x:Name="ButtonPresetEwfInfo" Content="EWF Info" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetEwfAcquire" Content="EWF Acquire" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetEwfAcquireStream" Content="EWF Acquire Stream" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetEwfRawCopy" Content="EWF RawCopy API" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetEwfRawCopyCpp" Content="EWF RawCopy C++" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetEwfExport" Content="EWF Export" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetEwfVerify" Content="EWF Verify" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetEwfRecover" Content="EWF Recover" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetEwfMount" Content="EWF Mount" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetEwfUnmount" Content="EWF Unmount" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetEwfMounts" Content="EWF Mounts" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetEwfDebug" Content="EWF Debug" Style="{StaticResource DarkButton}"/>
                            </WrapPanel>
                            <TextBlock Text="Preset READ rapidi:" Foreground="{StaticResource SubTxt}" Margin="0,4,0,6"/>
                            <WrapPanel>
                                <Button x:Name="ButtonPresetReadInfo" Content="Read Info" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetReadLs" Content="Read LS" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetReadTree" Content="Read Tree" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetReadCat" Content="Read Cat" Style="{StaticResource DarkButton}"/>
                                <Button x:Name="ButtonPresetReadExtract" Content="Read Extract" Style="{StaticResource DarkButton}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,12,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <Label Content="Endpoint"/>
                            <ComboBox x:Name="ComboBoxEndpointSelector" Height="34"/>
                            <Button x:Name="ButtonExecuteEndpoint" Content="Esegui endpoint" Height="36"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Label Content="Payload JSON"/>
                            <TextBox x:Name="TextBoxPayload" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="120"/>
                        </StackPanel>
                    </Grid>

                    <RichTextBox x:Name="LogBox" Grid.Row="2" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#0F1727" Foreground="{StaticResource Txt}" BorderBrush="#365276"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
